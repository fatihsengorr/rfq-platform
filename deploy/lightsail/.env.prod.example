APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com

POSTGRES_DB=rfq_platform
POSTGRES_USER=rfq
POSTGRES_PASSWORD=change-this-password
DATABASE_URL=postgresql://rfq:change-this-password@postgres:5432/rfq_platform

API_BASE_URL=http://api:4000
PUBLIC_API_BASE_URL=https://api.example.com
APP_WEB_BASE_URL=https://app.example.com
AUTH_JWT_SECRET=replace-with-a-long-random-secret
ALLOW_LEGACY_PASSWORD_UPGRADE=false

BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=ReplaceWithAStrongPassword123!
BOOTSTRAP_ADMIN_NAME=Platform Admin

STORAGE_ENDPOINT=s3.eu-central-1.amazonaws.com
STORAGE_PORT=443
STORAGE_USE_SSL=true
STORAGE_ACCESS_KEY=AKIAXXXXXXXXXXXXXXXX
STORAGE_SECRET_KEY=replace-with-aws-secret
STORAGE_REGION=eu-central-1
STORAGE_BUCKET=rfq-attachments-prod
